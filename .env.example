# Marabu node configuration
# Copy to .env and adjust as needed: cp .env.example .env

# Port the node listens on (host and container). Docker Compose maps this port.
MARABU_PORT=18018

# (MARABU_HOST and MARABU_PEERS_FILE are set in docker-compose.yml when using Docker.)

# Node version string reported to peers
# MARABU_VERSION=0.10.0

# User-Agent string reported to peers
# MARABU_AGENT=Siesto/0.10.0

# Reconnect interval in milliseconds for the outbound dial loop
# MARABU_RECONNECT_INTERVAL_MS=30000

# Set to 1, true, yes, or on to disable bootstrap peer injection
# MARABU_DISABLE_BOOTSTRAP=
