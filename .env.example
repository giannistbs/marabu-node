# Marabu node configuration

# Port the node listens on (host and container). Docker Compose maps this port.
MARABU_PORT=18018
MINER_NAME=Siesto
NUM_OF_WORKERS=1

# Host/interface the node binds to
# MARABU_HOST=0.0.0.0

# Peer store file path
# MARABU_PEERS_FILE=./data/peers.json

# LevelDB directory for persisted application objects
# MARABU_OBJECT_STORE_PATH=./data/object-store

# Reconnect interval in milliseconds for the outbound dial loop
# MARABU_RECONNECT_INTERVAL_MS=30000
